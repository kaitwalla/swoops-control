# nginx configuration for Swoops production deployment
# Copy to /etc/nginx/sites-available/swoops
#
# Setup:
#   1. Replace "swoops.example.com" with your domain
#   2. Copy to sites-available:
#      sudo cp nginx.conf.example /etc/nginx/sites-available/swoops
#   3. Enable the site:
#      sudo ln -s /etc/nginx/sites-available/swoops /etc/nginx/sites-enabled/
#   4. Test configuration:
#      sudo nginx -t
#   5. Obtain Let's Encrypt certificate:
#      sudo certbot --nginx -d swoops.example.com
#   6. Reload nginx:
#      sudo systemctl reload nginx

# HTTP to HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name swoops.example.com;

    # Allow certbot challenges
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # Redirect all other traffic to HTTPS
    location / {
        return 301 https://$server_name$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name swoops.example.com;

    # SSL certificates (managed by certbot)
    # certbot will automatically update these paths
    ssl_certificate /etc/letsencrypt/live/swoops.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/swoops.example.com/privkey.pem;

    # SSL configuration (Mozilla Intermediate)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;

    # SSL session caching
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    # OCSP stapling
    ssl_stapling on;
    ssl_stapling_verify on;
    ssl_trusted_certificate /etc/letsencrypt/live/swoops.example.com/chain.pem;
    resolver 8.8.8.8 8.8.4.4 valid=300s;
    resolver_timeout 5s;

    # Security headers
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Proxy settings for Swoops
    location / {
        # Proxy to Swoops HTTP API
        # For Docker: change to http://swoopsd:8080
        proxy_pass http://127.0.0.1:8080;

        # HTTP version
        proxy_http_version 1.1;

        # Headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;

        # WebSocket support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Timeouts for WebSocket connections
        proxy_connect_timeout 7d;
        proxy_send_timeout 7d;
        proxy_read_timeout 7d;

        # Buffering
        proxy_buffering off;
        proxy_request_buffering off;
    }

    # Optional: Separate location for metrics (restrict access)
    # location /metrics {
    #     # Restrict to internal IPs
    #     allow 10.0.0.0/8;
    #     allow 172.16.0.0/12;
    #     allow 192.168.0.0/16;
    #     deny all;
    #
    #     proxy_pass http://127.0.0.1:8080/metrics;
    # }

    # Access logging
    access_log /var/log/nginx/swoops-access.log combined;
    error_log /var/log/nginx/swoops-error.log warn;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/json application/javascript application/xml+rss application/rss+xml application/atom+xml image/svg+xml text/x-component;
}

# Note: gRPC agents connect directly to port 9090 (not through nginx)
# Swoops handles TLS/mTLS for gRPC connections directly

# Optional: Separate server block for metrics on subdomain
# server {
#     listen 443 ssl http2;
#     server_name metrics.swoops.example.com;
#
#     ssl_certificate /etc/letsencrypt/live/metrics.swoops.example.com/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/metrics.swoops.example.com/privkey.pem;
#
#     # Restrict to monitoring IPs
#     allow 10.0.0.0/8;
#     deny all;
#
#     location / {
#         proxy_pass http://127.0.0.1:8080;
#     }
# }
